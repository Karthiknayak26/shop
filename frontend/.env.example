# Kandukuru Supermarket - Frontend Environment Variables
# Create a copy of this file named ".env" or ".env.local" and populate the values

# URL of the backend API (defaults to localhost:5000 in development)
REACT_APP_API_URL=http://localhost:5000

# Razorpay public key (e.g. rzp_test_XXXX or rzp_live_XXXX)
REACT_APP_RAZORPAY_KEY_ID=rzp_test_YOUR_TEST_KEY_ID

# Razorpay mode (test or live)
REACT_APP_RAZORPAY_MODE=test
